{
  "name": "clarte",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && vite build --mode background && vite build --mode content && vite build --mode options && cp manifest.json dist/manifest.json",
    "build:background": "vite build --mode background",
    "build:content": "vite build --mode content",
    "build:options": "vite build --mode options",
    "dev:watch": "vite build --watch --mode background",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.17.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "svelte": "^5.55.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tsconfig/svelte": "^5.0.4",
    "@types/chrome": "^0.1.27",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "shadcn-svelte": "^0.14.3",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3",
    "vite": "^8.0.3"
  }
}
